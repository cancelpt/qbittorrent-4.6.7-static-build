QBT_STATIC_CONTAINER_IMAGE=buildpack-deps:noble
QBT_STATIC_UPSTREAM_REPO=https://github.com/userdocs/qbittorrent-nox-static.git
QBT_STATIC_UPSTREAM_REF=a67e830

QBT_STATIC_QB_TAG=release-4.6.7
QBT_STATIC_LT_VERSION=1.2.20
QBT_STATIC_LT_FALLBACK_VERSION=1.2.19
QBT_STATIC_QT_VERSION=6
QBT_STATIC_BUILD_TOOL=cmake
QBT_STATIC_WORKFLOW_FILES=yes
QBT_STATIC_GLIBC_TAG=glibc-2.43
QBT_STATIC_APT_MIRROR=http://mirrors.ustc.edu.cn/ubuntu/
QBT_STATIC_GNU_MIRROR=https://mirrors.sjtug.sjtu.edu.cn/gnu

QBT_STATIC_STATE_DIR=build/qbt-static
QBT_STATIC_OUTPUT_DIR=build/qbt-static/output
QBT_STATIC_LOG_DIR=build/qbt-static/logs
QBT_STATIC_CACHE_DIR=build/qbt-static/cache
QBT_STATIC_WORK_DIR=build/qbt-static/work
QBT_STATIC_PATCH_OVERLAY_DIR=packaging/qbt-static/patches
QBT_STATIC_LT_RETENTION_OVERLAY_SOURCE_DIR=packaging/qbt-source-overlays/lt-retention-narrow

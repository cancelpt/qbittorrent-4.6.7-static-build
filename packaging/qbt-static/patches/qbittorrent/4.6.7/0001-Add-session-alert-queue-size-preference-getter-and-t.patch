     void setBdecodeDepthLimit(int value);
     int getBdecodeTokenLimit() const;
     void setBdecodeTokenLimit(int value);
+    int sessionAlertQueueSize() const;
 
     // Stuff that don't appear in the Options GUI but are saved
     // in the same file.

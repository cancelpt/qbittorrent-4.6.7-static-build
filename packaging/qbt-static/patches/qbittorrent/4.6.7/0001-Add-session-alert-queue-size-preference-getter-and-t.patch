Subject: [PATCH 1/4] Add session alert queue size preference getter and tests

---
 src/base/preferences.cpp |  6 +++
 src/base/preferences.h   |  1 +
 test/CMakeLists.txt      |  1 +
 test/testpreferences.cpp | 96 ++++++++++++++++++++++++++++++++++++++++
 4 files changed, 104 insertions(+)
 create mode 100644 test/testpreferences.cpp

diff --git a/src/base/preferences.cpp b/src/base/preferences.cpp
index 4555247..4f3575a 100644
--- a/src/base/preferences.cpp
+++ b/src/base/preferences.cpp
@@ -332,6 +332,12 @@ void Preferences::setBdecodeTokenLimit(const int value)
     setValue(u"BitTorrent/BdecodeTokenLimit"_s, value);
 }
 
+int Preferences::sessionAlertQueueSize() const
+{
+    const int queueSize = value<int>(u"BitTorrent/SessionAlertQueueSize"_s, 10'000);
+    return ((queueSize >= 100) ? queueSize : 100);
+}
+
 bool Preferences::isToolbarDisplayed() const
 {
     return value(u"Preferences/General/ToolbarDisplayed"_s, true);
diff --git a/src/base/preferences.h b/src/base/preferences.h

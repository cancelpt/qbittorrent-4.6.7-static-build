+#include <memory>
+
+#include <libtorrent/create_torrent.hpp>
+#include <libtorrent/file_storage.hpp>
+#include <libtorrent/torrent_handle.hpp>
+#include <libtorrent/torrent_info.hpp>
+
+#include <QTest>
+
+#include "base/bittorrent/torrentstatusquery.h"
+
+using namespace BitTorrent;
+
+namespace
+{
+    std::shared_ptr<const lt::torrent_info> makeTorrentInfo()
+    {
+        lt::file_storage storage;
+        storage.add_file("payload.bin", 16 * 1024);
+
+        lt::create_torrent torrent {storage, 16 * 1024};
+        torrent.set_creator("qbt-test");
+
+        std::vector<char> encoded;
+        lt::bencode(std::back_inserter(encoded), torrent.generate());
+
+        return std::make_shared<lt::torrent_info>(encoded, lt::from_span);
+    }
+}
+
+class TestTorrentStatusQuery final : public QObject
+{
+    Q_OBJECT
+    Q_DISABLE_COPY_MOVE(TestTorrentStatusQuery)
+
+public:
+    TestTorrentStatusQuery() = default;
+
+private slots:
+    void steadyStateRefreshFlagsExcludeHeavyOptionalFields() const
+    {
+        const lt::status_flags_t flags = TorrentStatusQuery::steadyStateRefreshFlags();
+
+        QVERIFY(flags & lt::torrent_handle::query_pieces);
+        QVERIFY(flags & lt::torrent_handle::query_name);
+        QVERIFY(flags & lt::torrent_handle::query_save_path);
+        QVERIFY(flags & lt::torrent_handle::query_distributed_copies);
+        QVERIFY(flags & lt::torrent_handle::query_accurate_download_counters);
+        QVERIFY(flags & lt::torrent_handle::query_last_seen_complete);
+
+        QVERIFY(!(flags & lt::torrent_handle::query_verified_pieces));
+        QVERIFY(!(flags & lt::torrent_handle::query_torrent_file));
+    }
+
+    void resolveNativeTorrentInfoUsesCachedValueWithoutLoader() const
+    {
+        const std::shared_ptr<const lt::torrent_info> expectedTorrentInfo = makeTorrentInfo();
+        std::weak_ptr<const lt::torrent_info> cachedTorrentInfo = expectedTorrentInfo;
+        int loaderCallCount = 0;
+
+        const std::shared_ptr<const lt::torrent_info> resolvedTorrentInfo
+            = TorrentStatusQuery::resolveNativeTorrentInfo(cachedTorrentInfo, [&loaderCallCount]() -> std::shared_ptr<const lt::torrent_info>
+        {
+            ++loaderCallCount;
+            return {};
+        });
+
+        QCOMPARE(loaderCallCount, 0);
+        QCOMPARE(resolvedTorrentInfo.get(), expectedTorrentInfo.get());
+        QCOMPARE(cachedTorrentInfo.lock().get(), expectedTorrentInfo.get());
+    }
+
+    void resolveNativeTorrentInfoLoadsAndCachesValueOnDemand() const
+    {
+        std::weak_ptr<const lt::torrent_info> cachedTorrentInfo;
+        int loaderCallCount = 0;
+        const std::shared_ptr<const lt::torrent_info> expectedTorrentInfo = makeTorrentInfo();
+
+        const std::shared_ptr<const lt::torrent_info> resolvedTorrentInfo
+            = TorrentStatusQuery::resolveNativeTorrentInfo(cachedTorrentInfo, [&loaderCallCount, &expectedTorrentInfo]() -> std::shared_ptr<const lt::torrent_info>
+        {
+            ++loaderCallCount;
+            return expectedTorrentInfo;
+        });
+
+        QCOMPARE(loaderCallCount, 1);
+        QCOMPARE(resolvedTorrentInfo.get(), expectedTorrentInfo.get());
+        QCOMPARE(cachedTorrentInfo.lock().get(), expectedTorrentInfo.get());
+    }
+};
+
+QTEST_APPLESS_MAIN(TestTorrentStatusQuery)
+#include "testtorrentstatusquery.moc"

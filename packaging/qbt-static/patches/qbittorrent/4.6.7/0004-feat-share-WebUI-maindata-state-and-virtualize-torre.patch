+import assert from "node:assert/strict";
+import fs from "node:fs";
+import http from "node:http";
+import path from "node:path";
+import test from "node:test";
+import {createRequire} from "node:module";
+import {fileURLToPath} from "node:url";
+
+const __dirname = path.dirname(fileURLToPath(import.meta.url));
+const repoRoot = path.resolve(__dirname, "../..");
+const fixturePath = path.join(repoRoot, "test/webui/fixtures/virtualized-torrent-list-browser.html");
+const fixtureUrlPath = "/test/webui/fixtures/virtualized-torrent-list-browser.html";
+
+const requireFromSmokeWorkspace = createRequire("/tmp/qbt-webui-browser-smoke/package.json");
+const {chromium} = requireFromSmokeWorkspace("playwright-chromium");
+
+let server;
+let browser;
+let baseUrl;
+
+const sendNotFound = (response) => {
+    response.writeHead(404, {"Content-Type": "text/plain; charset=utf-8"});
+    response.end("Not found");
+};
+
+const contentTypeFor = (filePath) => {
+    if (filePath.endsWith(".html"))
+        return "text/html; charset=utf-8";
+    if (filePath.endsWith(".js"))
+        return "text/javascript; charset=utf-8";
+    if (filePath.endsWith(".css"))
+        return "text/css; charset=utf-8";
+    if (filePath.endsWith(".svg"))
+        return "image/svg+xml";
+    return "application/octet-stream";
+};
+
+test.before(async () => {
+    server = http.createServer((request, response) => {
+        const requestUrl = new URL(request.url, "http://127.0.0.1");
+        const decodedPath = decodeURIComponent(requestUrl.pathname);
+        const filePath = path.join(repoRoot, decodedPath);
+
+        if (!filePath.startsWith(repoRoot))
+            return sendNotFound(response);
+
+        fs.readFile(filePath, (error, contents) => {
+            if (error)
+                return sendNotFound(response);
+
+            response.writeHead(200, {"Content-Type": contentTypeFor(filePath)});
+            response.end(contents);
+        });
+    });
+
+    await new Promise((resolve) => {
+        server.listen(0, "127.0.0.1", resolve);
+    });
+
+    const address = server.address();
+    baseUrl = `http://127.0.0.1:${address.port}`;
+    browser = await chromium.launch({headless: true});
+});
+
+test.after(async () => {
+    await browser?.close();
+    await new Promise((resolve, reject) => {
+        server?.close((error) => {
+            if (error)
+                reject(error);
+            else
+                resolve();
+        });
+    });
+});
+
+async function openSmokePage() {
+    const page = await browser.newPage();
+    await page.goto(baseUrl + fixtureUrlPath);
+    await page.waitForFunction(() => (typeof window.browserSmokeApi === "object"));
+    return page;
+}
+
+test("browser smoke keeps torrent row DOM bounded and preserves selection interactions", async () => {
+    const page = await openSmokePage();
+
+    await page.evaluate(() => window.browserSmokeApi.loadTorrents(50000));
+
+    await page.waitForFunction(() => (window.browserSmokeApi.getMountedRowCount() > 0));
+    assert.equal(await page.evaluate(() => window.browserSmokeApi.getMountedRowCount()), 5);
+
+    await page.locator('[data-row-id="torrent-0"]').click();
+    await page.locator('[data-row-id="torrent-1"]').click({modifiers: ["Control"]});
+    assert.deepEqual(await page.evaluate(() => window.browserSmokeApi.getSelectedRowIds()), ["torrent-0", "torrent-1"]);
+
+    await page.locator('[data-row-id="torrent-1"]').click();
+    await page.locator('[data-row-id="torrent-4"]').click({modifiers: ["Shift"]});
+    assert.deepEqual(await page.evaluate(() => window.browserSmokeApi.getSelectedRowIds()), ["torrent-1", "torrent-2", "torrent-3", "torrent-4"]);
+
+    await page.evaluate(() => window.browserSmokeApi.scrollToIndex(50));
+    await page.waitForFunction(() => document.querySelector('[data-row-id="torrent-50"]') !== null);
+    await page.locator('[data-row-id="torrent-50"]').click({button: "right"});
+    assert.deepEqual(await page.evaluate(() => window.browserSmokeApi.getSelectedRowIds()), ["torrent-50"]);
+    assert.equal(await page.evaluate(() => window.browserSmokeApi.getMountedRowCount()), 7);
+
+    await page.close();
+});
+
+test("browser smoke preserves double-click actions and tbody rebuilds", async () => {
+    const page = await openSmokePage();
+
+    await page.evaluate(() => window.browserSmokeApi.loadTorrents(2, {
+        activeIndexes: [1]
+    }));
+
+    await page.locator('[data-row-id="torrent-0"]').dblclick();
+    let counters = await page.evaluate(() => window.browserSmokeApi.getActionCounters());
+    assert.equal(counters.startCalls, 1);
+    assert.equal(counters.pauseCalls, 0);
+    assert.ok(counters.propertiesUpdates >= 1);
+    assert.deepEqual(await page.evaluate(() => window.browserSmokeApi.getSelectedRowIds()), ["torrent-0"]);
+    const firstPropertiesUpdates = counters.propertiesUpdates;
+
+    await page.locator('[data-row-id="torrent-1"]').dblclick();
+    counters = await page.evaluate(() => window.browserSmokeApi.getActionCounters());
+    assert.equal(counters.startCalls, 1);
+    assert.equal(counters.pauseCalls, 1);
+    assert.ok(counters.propertiesUpdates > firstPropertiesUpdates);
+    assert.deepEqual(await page.evaluate(() => window.browserSmokeApi.getSelectedRowIds()), ["torrent-1"]);
+
+    await page.evaluate(() => {
+        window.browserSmokeApi.clearTbodyAndRefresh();
+    });
+    assert.equal(await page.evaluate(() => window.browserSmokeApi.getMountedRowCount()), 2);
+
+    await page.close();
+});
+
+test("browser smoke preserves sorting and column visibility with virtual rows", async () => {
+    const page = await openSmokePage();
+
+    await page.evaluate(async () => {
+        await window.browserSmokeApi.loadTorrents(100);
+        window.browserSmokeApi.reverseNameSort();
+    });
+
+    await page.waitForFunction(() => document.querySelector('[data-row-id="torrent-99"]') !== null);
+    assert.equal(await page.evaluate(() => window.browserSmokeApi.getFirstMountedRowId()), "torrent-99");
+
+    await page.evaluate(() => {
+        window.browserSmokeApi.toggleNameColumn(false);
+    });
+    assert.equal(await page.evaluate(() => window.browserSmokeApi.areMountedNameCellsHidden()), true);
+
+    await page.evaluate(() => {
+        window.browserSmokeApi.toggleNameColumn(true);
+    });
+    assert.equal(await page.evaluate(() => window.browserSmokeApi.areMountedNameCellsHidden()), false);
+
+    await page.close();
+});

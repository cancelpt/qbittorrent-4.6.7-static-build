+import assert from "node:assert/strict";
+import path from "node:path";
+import test from "node:test";
+import {fileURLToPath, pathToFileURL} from "node:url";
+
+const __dirname = path.dirname(fileURLToPath(import.meta.url));
+const helperModulePath = path.resolve(__dirname, "../../src/webui/www/private/scripts/torrent-list-state.js");
+const dynamicTableModulePath = path.resolve(__dirname, "../../src/webui/www/private/scripts/dynamicTable.js");
+
+const helperModule = await import(pathToFileURL(helperModulePath).href);
+const TorrentListState = helperModule.default ?? helperModule;
+
+globalThis.window = {
+    qBittorrent: {
+        TorrentListState,
+        FileTree: {
+            FileTree: function() {}
+        }
+    }
+};
+
+globalThis.Class = function(definition) {
+    const Parent = definition.Extends ?? null;
+
+    function Klass() {
+        if (typeof this.initialize === "function")
+            this.initialize.apply(this, arguments);
+    }
+
+    if (Parent) {
+        Klass.prototype = Object.create(Parent.prototype);
+        Klass.prototype.constructor = Klass;
+    }
+
+    for (const [key, value] of Object.entries(definition)) {
+        if (key !== "Extends")
+            Klass.prototype[key] = value;
+    }
+
+    return Klass;
+};
+
+globalThis.$ = function() {
+    throw new Error("DOM access is not expected when logical row order is enabled");
+};
+
+await import(pathToFileURL(dynamicTableModulePath).href);
+
+const {TorrentsTable} = globalThis.window.qBittorrent.DynamicTable;
+
+const createLogicalTable = ({selectedRows = [], stubEnsureRowIsVisible = true} = {}) => {
+    const table = new TorrentsTable();
+    const calls = [];
+    const logicalRows = [
+        {rowId: "torrent-a"},
+        {rowId: "torrent-b"},
+        {rowId: "torrent-c"}
+    ];
+
+    table.logicalRowOrderEnabled = true;
+    table.logicalRows = logicalRows;
+    table.rowOrderState = TorrentListState.buildRowOrderState(logicalRows);
+    table.selectedRows = selectedRows.slice();
+    table.deselectAll = function() {
+        calls.push(["deselectAll"]);
+        this.selectedRows = [];
+    };
+    table.selectRow = function(rowId) {
+        calls.push(["selectRow", rowId]);
+        this.selectedRows.push(rowId);
+    };
+    if (stubEnsureRowIsVisible) {
+        table.ensureRowIsVisible = function(rowId) {
+            calls.push(["ensureRowIsVisible", rowId]);
+        };
+    }
+
+    return {table, calls};
+};
+
+test("selectNextRow uses logical row order and requests visibility without DOM traversal", () => {
+    const {table, calls} = createLogicalTable({selectedRows: ["torrent-b"]});
+
+    table.selectNextRow();
+
+    assert.deepEqual(calls, [
+        ["deselectAll"],
+        ["selectRow", "torrent-c"],
+        ["ensureRowIsVisible", "torrent-c"]
+    ]);
+    assert.deepEqual(table.selectedRows, ["torrent-c"]);
+});
+

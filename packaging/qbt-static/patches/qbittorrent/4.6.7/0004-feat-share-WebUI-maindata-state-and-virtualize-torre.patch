+        let index = this.indexOf(value);
+        while (index !== -1) {
+            this.splice(index, 1);
+            index = this.indexOf(value);
+        }
+        return this;
+    };
+}
+
+if (!Array.prototype.empty) {
+    Array.prototype.empty = function() {

+        builder.print(QByteArrayLiteral("alpha"), Http::CONTENT_TYPE_TXT);
+        builder.print(QByteArrayLiteral("beta"), Http::CONTENT_TYPE_TXT);
+
+        const Http::Response response = builder.response();
+        QCOMPARE(response.content, QByteArrayLiteral("alphabeta"));
+        QCOMPARE(response.headers.value(Http::HEADER_CONTENT_TYPE), Http::CONTENT_TYPE_TXT);
+    }
+
+    void responseHeadersExcludeBodyAfterPreparation() const
+    {
+        Http::Response response;
+        response.headers[Http::HEADER_CONTENT_TYPE] = Http::CONTENT_TYPE_JSON;
+        response.content = QByteArrayLiteral("{\"rid\":1}");
+
+        Http::prepareResponse(response);
+        const QByteArray headers = Http::responseHeadersToByteArray(response);
+
+        QVERIFY(headers.endsWith(QByteArrayLiteral("\r\n\r\n")));
+        QVERIFY(headers.contains(QByteArrayLiteral("content-length: 9\r\n")));
+        QVERIFY(headers.contains(QByteArrayLiteral("content-type: application/json\r\n")));
+        QVERIFY(headers.contains(QByteArrayLiteral("date: ")));
+        QVERIFY(!headers.contains(response.content));
+        QCOMPARE(response.content, QByteArrayLiteral("{\"rid\":1}"));
+    }
+
+    void toByteArrayMatchesPreparedHeadersPlusBody() const
+    {
+        Http::Response response;
+        response.headers[Http::HEADER_CONTENT_TYPE] = Http::CONTENT_TYPE_TXT;
+        response.content = QByteArrayLiteral("payload");
+
+        Http::Response prepared = response;
+        Http::prepareResponse(prepared);
+
+        const QByteArray headerBytes = Http::responseHeadersToByteArray(prepared);
+        const QByteArray combined = headerBytes + prepared.content;
+        QCOMPARE(Http::toByteArray(response), combined);
+    }
+};
+
+QTEST_APPLESS_MAIN(TestHttpResponseGenerator)
+#include "testhttpresponsegenerator.moc"

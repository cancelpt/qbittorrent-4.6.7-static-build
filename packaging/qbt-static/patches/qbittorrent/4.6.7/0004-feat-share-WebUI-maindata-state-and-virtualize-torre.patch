+class FakeElement {
+    constructor(tag) {
+        this.tag = tag;
+        this.children = [];
+        this.parent = null;
+        this.properties = Object.create(null);
+        this.styles = Object.create(null);
+        this.events = Object.create(null);
+        this.classes = new Set();
+        this.text = "";
+        this.html = "";
+        this.offsetHeight = (tag === "tr") ? 20 : 0;
+        this.clientHeight = 0;
+        this.offsetHeight = (tag === "tbody") ? 0 : this.offsetHeight;
+    }
+
+    get firstChild() {
+        return this.children[0] ?? null;
+    }
+
+    setProperty(name, value) {
+        this.properties[name] = value;
+        return this;
+    }
+
+    setAttribute(name, value) {
+        return this.setProperty(name, value);
+    }
+
+    getProperty(name) {
+        return this.properties[name];
+    }
+
+    setStyle(name, value) {
+        this.styles[name] = value;
+        return this;
+    }
+
+    getStyle(name) {
+        return this.styles[name] ?? "";
+    }
+
+    setStyles(styles) {
+        Object.assign(this.styles, styles);
+        return this;
+    }
+
+    set(name, value) {
+        if (name === "text")
+            this.text = value;
+        else if (name === "html")
+            this.html = value;
+        else
+            this.properties[name] = value;
+        return this;
+    }
+
+    addClass(className) {
+        this.classes.add(className);
+        return this;
+    }
+
+    removeClass(className) {
+        this.classes.delete(className);
+        return this;
+    }
+
+    hasClass(className) {
+        return this.classes.has(className);
+    }
+
+    addEvent(name, handler) {
+        this.events[name] = handler;
+        return this;
+    }
+
+    fireEvent(name, payload) {
+        return this.events[name]?.call(this, payload);
+    }
+
+    adopt(...children) {
+        for (const child of children.flat()) {
+            if (child.parent)
+                child.dispose();
+            child.parent = this;
+            this.children.push(child);
+        }
+        return this;
+    }
+
+    appendChild(child) {
+        return this.adopt(child);
+    }
+
+    inject(target, where) {
+        if (where === "before") {
+            const parent = target.parent;
+            const index = parent.children.indexOf(target);
+            if (this.parent)
+                this.dispose();
+            this.parent = parent;
+            parent.children.splice(index, 0, this);
+            return this;
+        }
+
+        return target.adopt(this);
+    }
+
+    injectInside(target) {
+        return target.adopt(this);
+    }
+
+    dispose() {
+        if (!this.parent)
+            return this;
+
+        const index = this.parent.children.indexOf(this);
+        if (index >= 0)
+            this.parent.children.splice(index, 1);
+        this.parent = null;
+        return this;
+    }
+
+    destroy() {
+        this.dispose();
+        this.destroyed = true;
+        return this;
+    }
+
+    removeChild(child) {
+        child.dispose();
+        return child;
+    }
+
+    getChildren(tag) {
+        if (!tag)
+            return this.children.slice();
+        return this.children.filter(child => child.tag === tag);
+    }
+
+    getElements(tag) {
+        return this.getChildren(tag);
+    }
+
+    getSize() {
+        return {y: this.offsetHeight};
+    }
+
+    focus() {
+        this.focused = true;
+        return this;
+    }
+
+    scrollIntoView() {
+        this.scrolledIntoView = true;
+    }
+}
+
+function createHash(initialRows = []) {
+    const map = new Map(initialRows.map(row => [row.rowId, row]));
+
+    return {
+        has: key => map.has(key),
+        get: key => map.get(key),
+        set: (key, value) => {
+            map.set(key, value);
+        },
+        erase: key => {
+            map.delete(key);
+        },
+        empty: () => {
+            map.clear();
+        },
+        getValues: () => Array.from(map.values()),
+        getKeys: () => Array.from(map.keys())

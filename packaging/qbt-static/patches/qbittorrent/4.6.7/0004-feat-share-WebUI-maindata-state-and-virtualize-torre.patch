+    WebUISync::MaindataSyncData makeBaseMaindata()
+    {
+        WebUISync::MaindataSyncData data;
+        data.categories.insert(u"alpha"_s, {{u"name"_s, u"alpha"_s}, {u"savePath"_s, u"/alpha"_s}});
+        data.tags = {u"tag1"_s};
+        data.torrents.insert(u"hash1"_s, {{u"name"_s, u"Ubuntu"_s}, {u"progress"_s, 50}});
+        data.trackers.insert(u"udp://tracker-a"_s, {u"hash1"_s});
+        data.serverState = {{u"refresh_interval"_s, 1500}};
+        return data;
+    }
+
+    WebUISync::MaindataSyncData makeRevisionTwoDelta()
+    {
+        WebUISync::MaindataSyncData data;
+        data.categories.insert(u"beta"_s, {{u"name"_s, u"beta"_s}, {u"savePath"_s, u"/beta"_s}});
+        data.removedCategories = QStringList {u"alpha"_s};
+        data.tags = {u"tag2"_s};
+        data.removedTags = QStringList {u"tag1"_s};
+        data.torrents.insert(u"hash1"_s, {{u"progress"_s, 75}});
+        data.trackers.insert(u"udp://tracker-b"_s, {u"hash1"_s});
+        data.removedTrackers = QStringList {u"udp://tracker-a"_s};
+        data.serverState = {{u"queueing"_s, true}};
+        return data;
+    }
+}
+
+class TestWebUIMaindataSync final : public QObject
+{
+    Q_OBJECT
+    Q_DISABLE_COPY_MOVE(TestWebUIMaindataSync)
+
+public:
+    TestWebUIMaindataSync() = default;
+
+private slots:
+    void firstRequestForcesFullUpdateAndStartsRidSequence() const
+    {
+        WebUISync::MaindataSessionCursor cursor;
+
+        const WebUISync::MaindataSyncPlan plan = WebUISync::planMaindataSync(cursor, 0, 7, 1);
+
+        QVERIFY(plan.fullUpdate);
+        QCOMPARE(plan.baseRevision, 0);
+        QCOMPARE(plan.targetRevision, 7);
+        QCOMPARE(plan.responseRid, 1);
+        QCOMPARE(cursor.acceptedRid, 0);
+        QCOMPARE(cursor.acceptedRevision, 0);
+        QCOMPARE(cursor.lastSentRid, 1);
+        QCOMPARE(cursor.lastSentRevision, 7);
+    }
+
+    void acknowledgedRidAdvancesAcceptedRevisionAndUsesIncrementalSync() const
+    {
+        WebUISync::MaindataSessionCursor cursor;
+
+        const WebUISync::MaindataSyncPlan firstPlan = WebUISync::planMaindataSync(cursor, 0, 4, 1);
+        QVERIFY(firstPlan.fullUpdate);
+
+        const WebUISync::MaindataSyncPlan secondPlan = WebUISync::planMaindataSync(cursor, 1, 9, 1);
+
+        QVERIFY(!secondPlan.fullUpdate);
+        QCOMPARE(secondPlan.baseRevision, 4);
+        QCOMPARE(secondPlan.targetRevision, 9);
+        QCOMPARE(secondPlan.responseRid, 2);
+        QCOMPARE(cursor.acceptedRid, 1);
+        QCOMPARE(cursor.acceptedRevision, 4);
+        QCOMPARE(cursor.lastSentRid, 2);
+        QCOMPARE(cursor.lastSentRevision, 9);
+    }
+
+    void staleAcceptedRevisionFallsBackToFullUpdate() const
+    {
+        WebUISync::MaindataSessionCursor cursor;
+
+        QVERIFY(WebUISync::planMaindataSync(cursor, 0, 3, 1).fullUpdate);
+        QVERIFY(!WebUISync::planMaindataSync(cursor, 1, 5, 1).fullUpdate);
+
+        const WebUISync::MaindataSyncPlan stalePlan = WebUISync::planMaindataSync(cursor, 1, 8, 6);
+
+        QVERIFY(stalePlan.fullUpdate);
+        QCOMPARE(stalePlan.baseRevision, 0);
+        QCOMPARE(stalePlan.targetRevision, 8);
+        QCOMPARE(stalePlan.responseRid, 3);
+        QCOMPARE(cursor.acceptedRid, 1);
+        QCOMPARE(cursor.acceptedRevision, 3);
+        QCOMPARE(cursor.lastSentRid, 3);
+        QCOMPARE(cursor.lastSentRevision, 8);
+    }
+
+    void acceptedRevisionImmediatelyBeforeRetainedWindowStaysIncremental() const
+    {
+        WebUISync::MaindataSessionCursor cursor;
+
+        QVERIFY(WebUISync::planMaindataSync(cursor, 0, 3, 1).fullUpdate);
+        QVERIFY(!WebUISync::planMaindataSync(cursor, 1, 5, 1).fullUpdate);
+
+        const WebUISync::MaindataSyncPlan boundaryPlan = WebUISync::planMaindataSync(cursor, 2, 7, 6);
+
+        QVERIFY(!boundaryPlan.fullUpdate);
+        QCOMPARE(boundaryPlan.baseRevision, 5);
+        QCOMPARE(boundaryPlan.targetRevision, 7);
+        QCOMPARE(boundaryPlan.responseRid, 3);
+        QCOMPARE(cursor.acceptedRid, 2);
+        QCOMPARE(cursor.acceptedRevision, 5);
+        QCOMPARE(cursor.lastSentRid, 3);
+        QCOMPARE(cursor.lastSentRevision, 7);
+    }
+
+    void unexpectedRidFallsBackToFullUpdate() const
+    {
+        WebUISync::MaindataSessionCursor cursor;
+
+        QVERIFY(WebUISync::planMaindataSync(cursor, 0, 3, 1).fullUpdate);
+        QVERIFY(!WebUISync::planMaindataSync(cursor, 1, 5, 1).fullUpdate);
+
+        const WebUISync::MaindataSyncPlan mismatchPlan = WebUISync::planMaindataSync(cursor, 77, 6, 1);
+
+        QVERIFY(mismatchPlan.fullUpdate);
+        QCOMPARE(mismatchPlan.baseRevision, 0);
+        QCOMPARE(mismatchPlan.targetRevision, 6);
+        QCOMPARE(mismatchPlan.responseRid, 3);
+    }
+
+    void responseRidWrapsBackToOneAfterOneMillion() const
+    {
+        WebUISync::MaindataSessionCursor cursor;
+        cursor.lastSentRid = 1000000;
+        cursor.lastSentRevision = 9;
+        cursor.acceptedRid = 1000000;
+        cursor.acceptedRevision = 9;
+
+        const WebUISync::MaindataSyncPlan plan = WebUISync::planMaindataSync(cursor, 1000000, 10, 1);
+
+        QVERIFY(!plan.fullUpdate);
+        QCOMPARE(plan.responseRid, 1);
+        QCOMPARE(cursor.lastSentRid, 1);
+        QCOMPARE(cursor.acceptedRid, 1000000);
+        QCOMPARE(cursor.acceptedRevision, 9);
+        QCOMPARE(cursor.lastSentRevision, 10);
+    }
+
+    void revisionStoreReplaysRetainedIncrementalChanges() const
+    {
+        WebUISync::MaindataRevisionStore store;
+        store.initialize(makeBaseMaindata());
+
+        WebUISync::MaindataSessionCursor cursor;
+        const QJsonObject firstResponse = store.buildResponse(cursor, 0);
+        QVERIFY(firstResponse.value(u"full_update"_s).toBool());
+        QCOMPARE(firstResponse.value(u"rid"_s).toInt(), 1);
+
+        store.storeRevision(makeRevisionTwoDelta());
+        QCOMPARE(store.currentRevision(), 2);
+        QCOMPARE(store.earliestRetainedRevision(), 2);
+
+        const QJsonObject incrementalResponse = store.buildResponse(cursor, 1);
+
+        QVERIFY(!incrementalResponse.value(u"full_update"_s).toBool());
+        QCOMPARE(incrementalResponse.value(u"rid"_s).toInt(), 2);
+
+        const QJsonObject categories = incrementalResponse.value(u"categories"_s).toObject();
+        QVERIFY(categories.contains(u"beta"_s));
+        QCOMPARE(categories.value(u"beta"_s).toObject().value(u"savePath"_s).toString(), u"/beta"_s);
+        QCOMPARE(incrementalResponse.value(u"categories_removed"_s).toArray().at(0).toString(), u"alpha"_s);
+
+        QCOMPARE(incrementalResponse.value(u"tags"_s).toArray().at(0).toString(), u"tag2"_s);
+        QCOMPARE(incrementalResponse.value(u"tags_removed"_s).toArray().at(0).toString(), u"tag1"_s);
+
+        const QJsonObject torrents = incrementalResponse.value(u"torrents"_s).toObject();
+        QCOMPARE(torrents.value(u"hash1"_s).toObject().value(u"progress"_s).toInt(), 75);
+        QVERIFY(!torrents.value(u"hash1"_s).toObject().contains(u"name"_s));
+
+        const QJsonObject trackers = incrementalResponse.value(u"trackers"_s).toObject();
+        QCOMPARE(trackers.value(u"udp://tracker-b"_s).toArray().at(0).toString(), u"hash1"_s);
+        QCOMPARE(incrementalResponse.value(u"trackers_removed"_s).toArray().at(0).toString(), u"udp://tracker-a"_s);
+
+        QCOMPARE(incrementalResponse.value(u"server_state"_s).toObject().value(u"queueing"_s).toBool(), true);
+    }
+
+    void revisionStoreFallsBackToFullUpdateAfterRetentionEviction() const
+    {
+        WebUISync::MaindataRevisionStore store(1, 1024 * 1024);
+        store.initialize(makeBaseMaindata());
+
+        WebUISync::MaindataSessionCursor cursor;
+        const QJsonObject firstResponse = store.buildResponse(cursor, 0);
+        QCOMPARE(firstResponse.value(u"rid"_s).toInt(), 1);
+
+        store.storeRevision(makeRevisionTwoDelta());
+
+        WebUISync::MaindataSyncData revisionThreeDelta;
+        revisionThreeDelta.serverState = {{u"refresh_interval"_s, 2000}};
+        store.storeRevision(revisionThreeDelta);
+
+        QCOMPARE(store.currentRevision(), 3);
+        QCOMPARE(store.earliestRetainedRevision(), 3);
+
+        const QJsonObject fullResponse = store.buildResponse(cursor, 1);
+
+        QVERIFY(fullResponse.value(u"full_update"_s).toBool());
+        QCOMPARE(fullResponse.value(u"rid"_s).toInt(), 2);
+        QCOMPARE(fullResponse.value(u"server_state"_s).toObject().value(u"refresh_interval"_s).toInt(), 2000);
+        QCOMPARE(fullResponse.value(u"server_state"_s).toObject().value(u"queueing"_s).toBool(), true);
+    }
+
+    void revisionStoreBuildsSerializedInitialFullUpdateForFreshSession() const
+    {
+        WebUISync::MaindataRevisionStore store;
+        store.initialize(makeBaseMaindata());
+
+        WebUISync::MaindataSessionCursor firstCursor;
+        const QByteArray firstResponse = store.buildInitialFullUpdateResponse(firstCursor, 0);
+        QVERIFY(!firstResponse.isEmpty());
+        QVERIFY(firstResponse.contains("\"full_update\":true"));
+        QVERIFY(firstResponse.contains("\"rid\":1"));
+        QVERIFY(firstResponse.contains("\"hash1\""));
+        QCOMPARE(firstCursor.lastSentRid, 1);
+        QCOMPARE(firstCursor.lastSentRevision, store.currentRevision());
+
+        WebUISync::MaindataSessionCursor secondCursor;
+        const QByteArray secondResponse = store.buildInitialFullUpdateResponse(secondCursor, 0);
+        QCOMPARE(secondResponse, firstResponse);
+
+        QVERIFY(store.buildInitialFullUpdateResponse(secondCursor, 1).isEmpty());
+    }
+};
+
+QTEST_APPLESS_MAIN(TestWebUIMaindataSync)
+#include "testwebuimaindatasync.moc"

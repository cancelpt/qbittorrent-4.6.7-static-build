+import assert from "node:assert/strict";
+import path from "node:path";
+import test from "node:test";
+import {fileURLToPath, pathToFileURL} from "node:url";
+
+const __dirname = path.dirname(fileURLToPath(import.meta.url));
+const modulePath = path.resolve(__dirname, "../../src/webui/www/private/scripts/torrent-list-state.js");
+
+async function loadApi() {
+    try {
+        const imported = await import(pathToFileURL(modulePath).href);
+        return imported.default ?? imported;
+    }
+    catch (error) {
+        if ((error.code === "ERR_MODULE_NOT_FOUND") || (error.code === "MODULE_NOT_FOUND"))
+            return {};
+        throw error;
+    }
+}
+
+test("buildRowOrderState indexes rows by logical order", async () => {
+    const api = await loadApi();
+
+    assert.equal(typeof api.buildRowOrderState, "function");
+
+    const state = api.buildRowOrderState([
+        {rowId: "torrent-c", full_data: {name: "C"}},
+        {rowId: "torrent-a", full_data: {name: "A"}},
+        {rowId: "torrent-b", full_data: {name: "B"}}
+    ]);
+
+    assert.deepEqual(state.rowIds, ["torrent-c", "torrent-a", "torrent-b"]);
+    assert.equal(state.rowIndexById["torrent-c"], 0);
+    assert.equal(state.rowIndexById["torrent-b"], 2);
+    assert.equal(state.rowsById["torrent-a"].full_data.name, "A");
+});
+
+test("getRangeSelection follows logical row order regardless of endpoint order", async () => {
+    const api = await loadApi();
+
+    assert.equal(typeof api.buildRowOrderState, "function");
+    assert.equal(typeof api.getRangeSelection, "function");
+
+    const state = api.buildRowOrderState([
+        {rowId: "a"},
+        {rowId: "b"},
+        {rowId: "c"},
+        {rowId: "d"}
+    ]);
+
+    assert.deepEqual(api.getRangeSelection(state, "b", "d"), ["b", "c", "d"]);
+    assert.deepEqual(api.getRangeSelection(state, "d", "b"), ["b", "c", "d"]);
+});
+
+test("getAdjacentRowId preserves current keyboard navigation semantics", async () => {
+    const api = await loadApi();
+
+    assert.equal(typeof api.buildRowOrderState, "function");
+    assert.equal(typeof api.getAdjacentRowId, "function");
+
+    const state = api.buildRowOrderState([
+        {rowId: "a"},
+        {rowId: "b"},
+        {rowId: "c"}
+    ]);
+
+    assert.equal(api.getAdjacentRowId(state, "a", 1), "b");
+    assert.equal(api.getAdjacentRowId(state, "b", -1), "a");
+    assert.equal(api.getAdjacentRowId(state, "missing", 1), "a");
+    assert.equal(api.getAdjacentRowId(state, "missing", -1), null);
+    assert.equal(api.getAdjacentRowId(state, "c", 1), null);
+});
+
+test("calculateWindowRange computes bounded virtual window and spacer heights", async () => {
+    const api = await loadApi();
+
+    assert.equal(typeof api.calculateWindowRange, "function");
+
+    const range = api.calculateWindowRange({
+        totalRows: 100,
+        rowHeight: 20,
+        scrollTop: 40,
+        viewportHeight: 60,
+        overscan: 2
+    });
+
+    assert.deepEqual(range, {
+        startIndex: 0,
+        endIndex: 6,
+        topSpacerHeight: 0,
+        bottomSpacerHeight: 1860
+    });
+});
